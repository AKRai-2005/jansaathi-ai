# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET_NAME=jansaathi-audio-bucket

# Groq API (for AI text generation - FREE and FAST)
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# AWS Bedrock Configuration (alternative to Groq)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_MAX_TOKENS=1024
BEDROCK_TEMPERATURE=0.7

# Feature Flags
# Set to 'true' to use AWS Bedrock instead of Groq for LLM
FEATURE_FLAG_USE_BEDROCK=true
# Set to 'true' to enable RAG (Retrieval-Augmented Generation) with OpenSearch
FEATURE_FLAG_USE_RAG=false
# Enable voice responses via AWS Polly
ENABLE_VOICE_RESPONSES=true

# OpenSearch Serverless Configuration (for RAG)
# Create an OpenSearch Serverless collection with vector search enabled
OPENSEARCH_ENDPOINT=https://your-collection-id.us-east-1.aoss.amazonaws.com
OPENSEARCH_REGION=us-east-1

# RAG Configuration
RAG_SIMILARITY_THRESHOLD=0.7
RAG_MAX_SCHEME_RESULTS=5
RAG_MAX_INTERACTION_RESULTS=3
RAG_ENABLE_LEARNING=true

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/webhook/telegram

# Server Configuration
PORT=3001
NODE_ENV=development
